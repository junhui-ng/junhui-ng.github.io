---
// src/layouts/BlogPost.astro
import Layout from './Layout.astro';
import BlogFooter from '../components/BlogFooter.astro';

// 1. Astro automatically provides 'headings' alongside frontmatter!
const { frontmatter, headings = [] } = Astro.props;

// Optional: Filter out h1 (usually the title) and h4/h5/h6 to keep the TOC clean
const toc = headings.filter((heading) => heading.depth > 1 && heading.depth <= 3);
---

<Layout title={frontmatter.title} maxWidth="max-w-5xl">
  
  <div class="flex flex-col lg:flex-row lg:items-start lg:gap-12">

    <aside class="hidden lg:block w-56 shrink-0 sticky top-24">
      <h3 class="text-xs font-mono font-bold text-zinc-500 uppercase tracking-wider mb-6">
        Table of Contents
      </h3>
      
      <nav class="flex flex-col space-y-3 text-sm text-zinc-600 dark:text-zinc-400">
        {toc.map((heading) => (
          <a 
            href={`#${heading.slug}`} 
            class="hover:text-stanford dark:hover:text-stanford-light transition-colors line-clamp-2"
            style={`margin-left: ${(heading.depth - 2) * 1}rem;`}
          >
            {heading.text}
          </a>
        ))}
      </nav>
    </aside>

    <div class="flex-1 min-w-0">
      
      <nav class="flex items-center text-sm text-zinc-500 dark:text-zinc-400 mb-8" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-2">
          <li>
            <a href="/blogs" class="hover:text-stanford dark:hover:text-stanford-light transition-colors">
              Blogs
            </a>
          </li>
          <li>
            <svg class="h-4 w-4 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </li>
          <li>
            <span class="text-zinc-900 dark:text-zinc-100 font-medium truncate max-w-[200px] sm:max-w-xs block" aria-current="page">
              {frontmatter.title}
            </span>
          </li>
        </ol>
      </nav>

      <div class="mb-10">
        <h1 class="text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-2">
          {frontmatter.title}
        </h1>
        <p class="text-zinc-500 dark:text-zinc-400 text-sm font-mono">
          {frontmatter.date}
        </p>
      </div>

      <article class="
        prose max-w-none 
        dark:prose-invert
        prose-a:text-stanford dark:prose-a:text-stanford-light prose-a:no-underline hover:prose-a:underline
        prose-headings:font-bold prose-headings:text-zinc-800 dark:prose-headings:text-zinc-100
        prose-img:rounded-xl
      ">
        <slot />
      </article>

      <BlogFooter />

    </div>
  </div>
</Layout>