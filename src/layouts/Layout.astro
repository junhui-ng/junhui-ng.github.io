---
// src/layouts/Layout.astro
import '../styles/global.css';
import 'remark-github-alerts/styles/github-colors-light.css';
import 'remark-github-alerts/styles/github-base.css';

interface Props {
    title: string;
    maxWidth?: string;
}

const { title, maxWidth = "max-w-2xl" } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content="AI Engineer Portfolio" />
        <meta name="viewport" content="width=device-width" />
        <link 
		rel="icon" 
		href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>👨🏻‍💻</text></svg>"
		/>
		<link
		rel="stylesheet"
		href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
		integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV"
		crossorigin="anonymous"
		>
        <title>{title}</title>

        <script is:inline>
            const theme = (() => {
                if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
                    return localStorage.getItem('theme');
                }
                if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                    return 'dark';
                }
                return 'light';
            })();
        
            if (theme === 'dark') {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
            window.localStorage.setItem('theme', theme);
        </script>
    </head>
    
    <body class="bg-zinc-50 text-zinc-900 dark:bg-zinc-950 dark:text-zinc-200 antialiased transition-colors duration-300 selection:bg-stanford selection:text-white dark:selection:bg-stanford-light dark:selection:text-zinc-900">
        
        <div class={`${maxWidth} mx-auto px-6 py-12`}>
            
            <nav class="flex justify-between items-center mb-16">
                <div class="flex gap-6 font-medium">
                    <a href="/" class="hover:text-stanford dark:hover:text-stanford-light transition-colors">About Me</a>
                    <a href="/blogs" class="hover:text-stanford dark:hover:text-stanford-light transition-colors">Blogs</a>
                </div>
                
                <button id="theme-toggle" class="p-2 rounded-full bg-zinc-200 dark:bg-zinc-800 text-zinc-800 dark:text-zinc-200 hover:scale-110 transition-transform" aria-label="Toggle Theme">
                    <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                    <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
                </button>
            </nav>

            <slot />
        </div>

        <script>
            const handleToggleClick = () => {
                const element = document.documentElement;
                element.classList.toggle("dark");
    
                const isDark = element.classList.contains("dark");
                localStorage.setItem("theme", isDark ? "dark" : "light");
            }
    
            document.getElementById("theme-toggle").addEventListener("click", handleToggleClick);
        </script>
    </body>
</html>

<style is:global>
  /* 1. Base Structure */
  @import 'remark-github-alerts/styles/github-base.css';

  /* 2. Light Mode Colors (GitHub Exact Hex Codes) */
  :root {
    --color-accent-fg: #0969da;
    --color-success-fg: #1a7f37;
    --color-attention-fg: #9a6700;
    --color-danger-fg: #d1242f;
    --color-done-fg: #8250df;
  }

  /* 3. Dark Mode Colors - Tied directly to your HTML 'dark' class */
  html.dark {
    --color-accent-fg: #2f81f7;
    --color-success-fg: #3fb950;
    --color-attention-fg: #d29922;
    --color-danger-fg: #f85149;
    --color-done-fg: #a371f7;
  }

  /* 4. Pixel-Perfect Overrides against Tailwind */
  .prose .markdown-alert {
    padding: 8px 16px !important;
    margin-top: 16px !important;
    margin-bottom: 16px !important;
    
    /* FIX: Force the width and style, but let the plugin determine the color! */
    border-left-width: 4px !important;
    border-left-style: solid !important;
    
    border-radius: 0 !important;
    background-color: transparent !important;
    color: inherit !important;
  }
  
  .prose .markdown-alert p {
    margin: 0 !important;
    font-size: 16px !important;
    line-height: 1.5 !important;
  }
  
  .prose .markdown-alert-title {
    display: flex !important;
    align-items: center !important;
    font-weight: 500 !important; /* GitHub uses 500, not 600 */
    font-size: 14px !important;
    margin-bottom: 4px !important;
    line-height: 1 !important;
  }

  .prose .markdown-alert-title svg {
    width: 16px !important;
    height: 16px !important;
    margin-right: 8px !important;
    margin-top: 0 !important;
    margin-bottom: 0 !important;
    fill: currentColor !important;
  }

  .prose .reference-list ol {
    list-style-type: none !important;
    counter-reset: ref-counter;
    padding-left: 1.7rem !important;
  }

  .prose .reference-list ol li {
    counter-increment: ref-counter;
    position: relative;
  }

  /* Draw the custom [1] marker */
  .prose .reference-list ol li::before {
    content: "[" counter(ref-counter) "]" !important;
    position: absolute;
    left: -1.75rem; /* Pushes the bracket into the margin */
    @apply text-stanford dark:text-stanford-light;
    font-size: 0.95em;
  }
</style>