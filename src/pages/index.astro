---
import Layout from '../layouts/Layout.astro';

const GITHUB_USERNAME = "junhui-ng";

// Profile
const profile = {
  name: "Ng Jun Hui",
  role: "AI Algorithm Engineer",
  bio: "MComp AI student at NUS.\nConstantly pondering the intersection of neuroscience and artificial intelligence.\n\nLet's talk!",
  socials: [
    { name: "GitHub", url: "https://github.com/junhui-ng", icon: "github" },
    { name: "LinkedIn", url: "https://www.linkedin.com/in/junhui-ng/", icon: "linkedin" },
    { name: "Email", url: "mailto:jh.ngjunhui@gmail.com", icon: "mail" },
  ]
};

// Work experience
const experience = [
  {
    role: "AI Research Intern",
    company: "Akro",
    description: "Cooking up cool stuff - TBD.",
    date: "Starting Jul 2026"
  },
  {
    role: "AI Algorithm Engineer Intern",
    company: "TikTok",
    description: "Made TikTok Tako better.",
    date: "Jan 2026 - Jun 2026"
  },
  {
    role: "AI Research Engineer",
    company: "FootfallCam",
    description: "Designed and built FootfallCam Centroid, an AI video analytics product.",
    date: "Apr 2024 - Jun 2025"
  },
  {
    role: "Computer Vision Engineer",
    company: "Tapway",
    description: "Developed computer vision systems for smart parking, agriculture, F&B, etc.",
    date: "Jan 2023 - Jan 2024"
  }
];

// Projects/repositories
const repoNames = [
  "ByteTrack-CPP", 
  "Hungarian-Algorithm-CPP"
];
// Dynamically load repo info at build time
const projects = await Promise.all(
  repoNames.map(async (repo) => {
    const response = await fetch(`https://api.github.com/repos/${GITHUB_USERNAME}/${repo}`);
    if (!response.ok) return null; // Handle missing repos safely
    
    const data = await response.json();
    
    return {
      title: data.name,
      desc: data.description || "",
      url: data.html_url,
      stars: data.stargazers_count,
      // Limit to 4 topics so cards don't get too tall
      tech: data.topics ? data.topics.slice(0, 4) : [] 
    };
  })
);
const validProjects = projects.filter(p => p !== null);

// Publication Section
const publications = [
  {
    title: "Multiview-based method for high-throughput quality classification of germinated oil palm seeds",
    journal: "Computers and Electronics in Agriculture",
    year: "2024",
    doi: "10.1016/j.compag.2024.108684",
    url: "https://doi.org/10.1016/j.compag.2024.108684",
    contribution: "First author. Supervised by Prof. Iman Yi Liao."
  }
];

---

<Layout title={`${profile.name} - ${profile.role}`}>

  <header class="mb-14">
    <h1 class="text-3xl font-bold tracking-tight text-zinc-900 dark:text-white sm:text-4xl mb-2">
      {profile.name}
    </h1>
    <p class="text-xl text-zinc-600 dark:text-zinc-400 font-medium mb-6">{profile.role}</p>
    
    <!-- Removed max-w-lg from this line so it matches the <hr> width -->
    <p class="whitespace-pre-line text-zinc-600 dark:text-zinc-400 leading-relaxed mb-8">
      {profile.bio}
    </p>
    
    <div class="flex gap-6 text-sm font-mono text-zinc-500 dark:text-zinc-500">
      {profile.socials.map(social => (
        <a href={social.url} class="hover:text-stanford dark:hover:text-stanford-light transition-colors" target="_blank">
          {social.name}
        </a>
      ))}
    </div>
  </header>

  <hr class="border-zinc-300 dark:border-zinc-800 mb-12" />

  <section class="mb-16">
    <h2 class="text-sm font-mono font-bold text-zinc-500 uppercase tracking-wider mb-6">Experience</h2>
    
    <div class="relative border-l-2 border-zinc-200 dark:border-zinc-800 ml-3 space-y-8 pb-2">
      
      {experience.map(job => (
        <div class="relative pl-8 group">
          <span class="absolute -left-[9px] top-1 h-4 w-4 rounded-full border-4 border-zinc-50 dark:border-zinc-950 bg-zinc-400 dark:bg-zinc-600 group-hover:bg-stanford dark:group-hover:bg-stanford-light transition-colors"></span>
          
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
            <h3 class="font-semibold text-zinc-900 dark:text-zinc-100 text-sm">
              {job.role}
              <span class="text-zinc-400 mx-2">·</span>
              <span class="text-zinc-600 dark:text-zinc-400">
                {job.company}
              </span>
            </h3>
            
            <span class="text-xs font-mono text-zinc-500 mt-1 sm:mt-0">
              {job.date}
            </span>
          </div>

          {/* Renders unconditionally to preserve vertical space */}
          <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed min-h-[1.25rem]">
            {job.description || "\u00A0"}
          </p>
        </div>
      ))}
    </div>
  </section>

  <hr class="border-zinc-300 dark:border-zinc-800 mb-12" />

  <section class="mb-16">
    <h2 class="text-sm font-mono font-bold text-zinc-500 uppercase tracking-wider mb-6">Selected Projects</h2>
    <div class="space-y-8">
      {validProjects.map(project => (
        <a href={project.url} target="_blank" class="group block">
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-1">
            <h3 class="font-semibold text-zinc-900 dark:text-zinc-100 group-hover:text-stanford dark:group-hover:text-stanford-light transition-colors">
              {project.title}
            </h3>
            
            <div class="flex items-center gap-1 text-xs text-zinc-500 font-mono mt-1 sm:mt-0">
               <svg class="w-3 h-3 text-yellow-500" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 22 20">
                  <path d="M20.924 7.625a1.523 1.523 0 0 0-1.238-1.044l-5.051-.734-2.259-4.577a1.534 1.534 0 0 0-2.752 0L7.365 5.847l-5.051.734A1.535 1.535 0 0 0 1.463 9.2l3.656 3.563-.863 5.031a1.532 1.532 0 0 0 2.226 1.616L11 17.033l4.518 2.375a1.534 1.534 0 0 0 2.226-1.617l-.863-5.03L20.537 9.2a1.523 1.523 0 0 0 .387-1.575Z"/>
               </svg>
               {project.stars}
            </div>
          </div>

          <p class="text-zinc-600 dark:text-zinc-400 text-sm leading-relaxed mb-3 mt-1">
            {project.desc}
          </p>
          
          <div class="flex gap-2 flex-wrap">
            {project.tech.map(t => (
              <span class="text-xs px-2 py-1 rounded bg-zinc-200 dark:bg-zinc-900 border border-zinc-300 dark:border-zinc-800 text-zinc-600 dark:text-zinc-500">
                {t}
              </span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>

  <hr class="border-zinc-300 dark:border-zinc-800 mb-12" />

  <section class="mb-16">
    <h2 class="text-sm font-mono font-bold text-zinc-500 uppercase tracking-wider mb-6">Publication</h2>
    <div class="space-y-6">
      {publications.map(pub => (
        <a href={pub.url} target="_blank" class="block group">
           <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between">
              <h3 class="font-semibold text-zinc-900 dark:text-zinc-100 group-hover:text-stanford dark:group-hover:text-stanford-light leading-tight">
                {pub.title}
              </h3>
           </div>
           
           <p class="text-sm text-zinc-600 dark:text-zinc-400 mt-2 leading-relaxed">
             {pub.journal} • {pub.year}
             <br/>
             <span class="text-zinc-500 dark:text-zinc-500 italic">
               {pub.contribution}
             </span>
           </p>
        </a>
      ))}
    </div>
  </section>

</Layout>
